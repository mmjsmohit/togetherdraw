{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "HTTP_BACKEND_HOST",
    "HTTP_BACKEND_PORT",
    "HOSTNAME",
    "NEXT_PUBLIC_HTTP_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "NODE_ENV",
    "PORT",
    "WS_BACKEND_HOST",
    "WS_BACKEND_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
